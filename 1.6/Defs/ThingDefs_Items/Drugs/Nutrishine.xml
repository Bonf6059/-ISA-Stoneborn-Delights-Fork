<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="DrugBase">
    <defName>ISA_Nutrishine</defName>
    <label>nutrishine</label>
    <description>A flavorful moonshine first homebrewed by baseliner to imitate the famous shroom ale made by stoneborn miners. Its ingredients make for a pale imitation of the original, but as much intoxicating. Many of its heaviest drinkers swear that if made correctly it is indistinguishable from the real thing, usually before getting laughed out of the tavern.</description>
    <descriptionHyperlinks>
      <HediffDef>ISA_NutrishineHigh</HediffDef>
      <HediffDef>SD_DwarvenBrewTolerance</HediffDef>
      <HediffDef>SD_DwarvenBrewAddiction</HediffDef>
      <HediffDef>SD_LightHangover</HediffDef>
      <HediffDef>Cirrhosis</HediffDef>
      <HediffDef>ChemicalDamageModerate</HediffDef>
    </descriptionHyperlinks>
    <possessionCount>6</possessionCount>
    <graphicData>
      <texPath>Things/Nutrishine</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <equippedAngleOffset>-150</equippedAngleOffset>
    <rotatable>false</rotatable>
    <stackLimit>30</stackLimit>
    <statBases>
      <DeteriorationRate>0.5</DeteriorationRate>
      <MarketValue>17</MarketValue>
      <Mass>0.3</Mass>
      <Flammability>0.5</Flammability>
      <Nutrition>0.13</Nutrition>
    </statBases>
    <ingestible>
      <foodType>Fluid, Processed, Liquor</foodType>
      <joyKind>Chemical</joyKind>
      <joy>0.17</joy>
      <nurseable>true</nurseable>
      <drugCategory>Social</drugCategory>
      <ingestSound>Ingest_Beer</ingestSound>
      <ingestHoldOffsetStanding/>
      <ingestCommandString>Drink {0}</ingestCommandString>
      <ingestReportString>Drinking {0}.</ingestReportString>
      <chairSearchRadius>25</chairSearchRadius>
      <canAutoSelectAsFoodForCaravan>false</canAutoSelectAsFoodForCaravan>
      <tableDesired>false</tableDesired>
      <outcomeDoers>
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>ISA_NutrishineHigh</hediffDef>
          <severity>0.12</severity>
          <toleranceChemical>SD_DwarvenDrink</toleranceChemical>
        </li>
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>SD_DwarvenBrewTolerance</hediffDef>
          <severity>0.012</severity>
          <divideByBodySize>true</divideByBodySize>
        </li>
      </outcomeDoers>
    </ingestible>
    <equipmentType>Primary</equipmentType>
    <techLevel>Neolithic</techLevel>
    <comps>
      <li Class="CompProperties_Drug">
        <chemical>SD_DwarvenDrink</chemical>
        <addictiveness>0.010</addictiveness>
        <minToleranceToAddict>0.23</minToleranceToAddict>
        <existingAddictionSeverityOffset>0.22</existingAddictionSeverityOffset>
        <needLevelOffset>0.4</needLevelOffset>
        <listOrder>10</listOrder>
      </li>
      <li>
        <compClass>CompEquippable</compClass>
      </li>
    </comps>
    <weaponClasses>
      <li>Melee</li>
      <li>MeleeBlunt</li>
    </weaponClasses>
    <tools>
      <li>
        <label>bottle</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>neck</label>
        <capacities>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
    <allowedArchonexusCount>50</allowedArchonexusCount>
  </ThingDef>

  <HediffDef>
    <defName>ISA_NutrishineHigh</defName>
    <label>nutrishine high</label>
    <labelNoun>drunkenness</labelNoun>
    <description>Nutrishine is in the blood stream, it makes people happy, and buffs accuracy even though your taste is questionable.</description>
    <hediffClass>Hediff_High</hediffClass>
    <defaultLabelColor>(1,0,0.5)</defaultLabelColor>
    <scenarioCanAdd>true</scenarioCanAdd>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_Effecter">
        <stateEffecter>AleDrunk</stateEffecter>
        <severityIndices>3~5</severityIndices>
      </li>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-0.75</severityPerDay>
        <showHoursToRecover>true</showHoursToRecover>
      </li>
      <li Class="StonebornDelights.HediffCompProperties_Hangover">
        <hangover>SD_LightHangover</hangover>
        <minHangoverStage>3</minHangoverStage>
      </li>
    </comps>
      <stages>
        <li>
          <label>warm</label>
		  
          <statOffsets>
		  
					<ShootingAccuracyPawn>1.75</ShootingAccuracyPawn>

		   </statOffsets>	
				
          <socialFightChanceFactor>1.9</socialFightChanceFactor>
            <capMods>
              <li>
                <capacity>Manipulation</capacity>
                <offset>-0.02</offset>
              </li>
            </capMods>
        </li>
		
        <li>
          <minSeverity>0.25</minSeverity>
		  
          <label>tipsy</label>
		  
		    <statOffsets>
			
					<ShootingAccuracyPawn>3.5</ShootingAccuracyPawn>

		    </statOffsets>	
		  
          <socialFightChanceFactor>3</socialFightChanceFactor>
            <capMods>
			   <li>
                <capacity>Manipulation</capacity>
                <offset>-0.05</offset>
              </li>
			  <li>
			   <capacity>Moving</capacity>
                <offset>-0.04</offset>
		      </li>
			  
            </capMods>
        </li>
        <li>
          <minSeverity>0.4</minSeverity>
		  
          <label>drunk</label>
		  
		    <statOffsets>
			
					<ShootingAccuracyPawn>8</ShootingAccuracyPawn>

		    </statOffsets>
		  
          <socialFightChanceFactor>4.5</socialFightChanceFactor>
          <vomitMtbDays>0.45</vomitMtbDays>
		  
          <tale>Drunk</tale>
		  
            <capMods>
              <li>
                <capacity>Manipulation</capacity>
                <postFactor>-0.25</postFactor>
              </li>
              <li>
                <capacity>Moving</capacity>
                <offset>-0.1</offset>
              </li>
            </capMods>
        </li>
        <li>
          <minSeverity>0.7</minSeverity>
		  
          <label>hammered</label>
		  
		  <statOffsets>
			
					<ShootingAccuracyPawn>13</ShootingAccuracyPawn>

		    </statOffsets>	
		  
          <socialFightChanceFactor>5</socialFightChanceFactor>
          <vomitMtbDays>0.45</vomitMtbDays>
            <capMods>
			   <li>
                <capacity>Manipulation</capacity>
                <offset>-0.32</offset>
              </li>
			  <li>
			   <capacity>Moving</capacity>
                <offset>-0.3</offset>
		      </li>
          
            </capMods>
        </li>
        <li>
          <minSeverity>0.9</minSeverity>
          <label>blackout</label>
          <painFactor>0.1</painFactor>
          <capMods>
            <li>
              <capacity>Consciousness</capacity>
              <setMax>0.1</setMax>
            </li>
          </capMods>
          <hediffGivers>
            <li Class="HediffGiver_Random">
              <hediff>ChemicalDamageModerate</hediff>
              <mtbDays>10</mtbDays>
              <partsToAffect>
                <li>Brain</li>
              </partsToAffect>
            </li>
          </hediffGivers>
        </li>
      </stages>
  </HediffDef>

  
  <ThoughtDef>
    <defName>ISA_Inebriated</defName>
    <workerClass>ThoughtWorker_Hediff</workerClass>
    <hediff>ISA_NutrishineHigh</hediff>
    <validWhileDespawned>true</validWhileDespawned>
    <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
    <stages>
      <li>
        <label>ale warmth</label>
        <description>I'm feeling a little bit energetic. That's good!</description>
        <baseMoodEffect>8</baseMoodEffect>
      </li>
      <li>
        <label>quite inebriated</label>
        <description>I'm itchin' to fight something...</description>
        <baseMoodEffect>12</baseMoodEffect>
      </li>     
      <li>
        <label>drunk</label>
        <description>I need'a gun! I need'a shoot something!</description>
        <baseMoodEffect>18</baseMoodEffect>
      </li>
      <li>
        <label>hammered</label>
        <description>Wooo! Kill those damn insectoids! Pew pew!</description>
        <baseMoodEffect>24</baseMoodEffect>
      </li>   
    </stages>
  </ThoughtDef>
  
